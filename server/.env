# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────────
# Get free cluster from https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/celova

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=celova_access_secret_change_in_production
JWT_REFRESH_SECRET=celova_refresh_secret_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cloudinary ─────────────────────────────────────────────────
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── YouTube Data API v3 ────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# ─── Stripe ──────────────────────────────────────────────────────
# Get from https://stripe.com/docs/keys
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Nodemailer ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# ─── Client ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
